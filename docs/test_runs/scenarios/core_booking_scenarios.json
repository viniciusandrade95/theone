          "user_message": "sim",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_no_rag_reset": true
        }
      ]
    },
    {
      "name": "booking_interrupted_then_resume",
      "description": "User asks an FAQ in the middle of booking and then resumes without losing valid slots.",
      "tags": ["booking", "interruption", "robustness"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 18h",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_slots_present": ["service", "date", "time"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "Qual o endereço mesmo?",
          "allow_rag_detour": true,
          "expected_workflow_not": ["handoff_to_human"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "Beleza, pode continuar",
          "expected_workflow": "book_appointment",
          "expected_slots_present": ["service", "date", "time"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        }
      ]
    },
    {
      "name": "booking_user_changes_time_mid_flow",
      "description": "User changes the requested time after the initial summary.",
      "tags": ["booking", "change_of_mind", "state"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 15h para Audit User, telefone 11999998888",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
