    {
      "name": "reschedule_happy_path",
      "description": "User requests remarcação with enough new date/time data; environment should have exactly one upcoming appointment or an explicit target.",
      "tags": ["reschedule", "happy_path", "crm_side_effect", "requires_existing_appointment"],
      "steps": [
        {
          "user_message": "quero remarcar meu corte para amanhã às 16h17",
          "expected_route": "workflow",
          "expected_workflow": "reschedule_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_reply_contains_any": ["remarcação", "confirmar", "confirmação"],
          "expected_slots_present": ["new_date", "new_time"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "sim, pode confirmar",
          "expected_route": "workflow",
          "expected_workflow": "reschedule_appointment",
          "expected_status": "completed",
          "expected_reply_contains_any": ["remarcação", "remarcado", "confirmada", "confirmado"],
          "expected_reply_not_contains": ["prebooking_stub", "erro técnico"],
          "expected_no_rag_reset": true
        }
      ]
    },
