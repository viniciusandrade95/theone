{
  "version": 1,
  "description": "Core live booking and rescheduling scenarios for theone -> chatbot1 hybrid evaluation.",
  "scenarios": [
    {
      "name": "booking_happy_path_full",
      "description": "User provides service, date, time, customer name, phone, and confirms a real prebook.",
      "tags": ["booking", "happy_path", "crm_side_effect"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 16h17 para Audit User, telefone 11999998888",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_reply_contains_any": ["confirmação", "confirmar", "tudo certo", "posso encaminhar", "pré-agendamento"],
          "expected_slots_present": ["service", "date", "time", "customer_name", "phone"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "sim, pode confirmar",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "completed",
          "expected_reply_contains_any": ["registr", "agend", "pré-agendamento", "confirm"],
          "expected_reply_not_contains": ["prebooking_stub", "erro técnico"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_action_result_fields": {
            "ok": true
          },
          "expected_no_rag_reset": true
        }
      ],
      "crm_verification": {
        "appointments": {
          "expect_created": true,
          "from_dt": "relative:tomorrow_start_utc",
          "to_dt": "relative:day_after_tomorrow_start_utc",
          "recent_created_within_seconds": 900,
          "match": {
            "start_time": "16:17",
            "service_id": "944cc6ff-4283-444f-bcc9-8281c5a5a9f6",
            "service_name_contains": "Corte"
          }
        }
      },
      "judge_expectations": {
        "minimum_naturalness_score": 3,
        "minimum_coherence_score": 4
      }
    },
    {
      "name": "booking_missing_name",
      "description": "User tries to confirm without customer identity; assistant must ask for name before execution.",
      "tags": ["booking", "missing_data", "guardrail"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 15h",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_slots_present": ["service", "date", "time"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "sim",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_reply_contains": ["nome"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "Audit User",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_reply_contains_any": ["confirmação", "confirmar", "tudo certo", "posso encaminhar", "pré-agendamento"],
          "expected_slots_present": ["service", "date", "time", "customer_name"],
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "pode confirmar",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "collecting",
          "expected_reply_contains": ["telefone"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_action_result_fields": {
            "missing_customer_phone": true
          },
          "expected_workflow_not": ["handoff_to_human"],
          "expected_no_rag_reset": true
        }
      ]
    },
    {
      "name": "booking_missing_phone",
      "description": "User starts without CRM customer identity; assistant must collect name first when needed, then phone before prebook callback.",
      "tags": ["booking", "missing_phone", "guardrail"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 15h",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_slots_present": ["service", "date", "time"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "pode confirmar",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "collecting",
          "expected_reply_contains": ["nome"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_action_result_fields": {
            "missing_customer_identity": true
          },
          "expected_no_rag_reset": true
        },
        {
          "user_message": "Audit User",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_reply_contains_any": ["confirmação", "confirmar", "tudo certo", "posso encaminhar"],
          "expected_slots_present": ["service", "date", "time", "customer_name"],
          "expected_no_rag_reset": true
        },
        {
          "user_message": "pode confirmar",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "collecting",
          "expected_reply_contains": ["telefone"],
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_action_result_fields": {
            "missing_customer_phone": true
          },
          "expected_no_rag_reset": true
        },
        {
          "user_message": "11999998888",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_status": "awaiting_confirmation",
          "expected_reply_contains_any": ["confirmação", "confirmar", "tudo certo", "posso encaminhar"],
          "expected_slots_present": ["service", "date", "time", "customer_name", "phone"],
          "expected_no_rag_reset": true
        }
      ]
    },
    {
      "name": "booking_conflict_slot",
      "description": "User requests a slot that may already be occupied; assistant should not fake success if CRM rejects it.",
      "tags": ["booking", "conflict", "crm_failure"],
      "steps": [
        {
          "user_message": "Quero marcar um corte amanhã às 15h para Audit User, telefone 11999998888",
          "expected_route": "workflow",
