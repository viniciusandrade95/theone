          "expected_no_rag_reset": true
        },
        {
          "user_message": "sim",
          "expected_route": "workflow",
          "expected_workflow": "book_appointment",
          "expected_reply_not_contains": ["prebooking_stub"],
          "expected_no_rag_reset": true
        }
      ]
    },
    {
      "name": "faq_then_booking",
      "description": "User starts with availability/FAQ language and then transitions into booking.",
      "tags": ["faq", "booking", "transition"],
      "steps": [
        {
          "user_message": "Tem vaga amanhã?",
          "expected_reply_not_contains": ["prebooking_stub"]
        },
        {
          "user_message": "Quero corte às 16h17 para Audit User, telefone 11999998888",
